---
interface Props {
  title?: string;
  subtitle?: string;
  id?: string;
  class?: string;
}

const { title, subtitle, id, class: className = '' } = Astro.props;
---

<section
  id={id}
  class:list={[
    'py-12 md:py-16 theme-transition',
    className,
  ]}
>
  <div class="container mx-auto px-4">
    {(title || subtitle) && (
      <div class="mb-8 md:mb-12">
        {title && (
          <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-gray-100">
            {title}
          </h2>
        )}
        {subtitle && (
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            {subtitle}
          </p>
        )}
      </div>
    )}

    <slot />
  </div>
</section>
