---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  dateRange: string;
  location: string;
  tags: string[];
  image: ImageMetadata;
  description?: string;
  link?: string;
  slug?: string;
}

const { title, dateRange, location, tags, image, description, link, slug } = Astro.props;
---

<article class="py-16">
  <div class="max-w-6xl mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-[minmax(200px,380px)_1fr] gap-8 lg:gap-12">
      <!-- Project Info - Left Column -->
      <div class="flex flex-col">
        <!-- Top metadata -->
        <div class="space-y-1 text-center lg:text-left">
          <h2 class="text-xl tracking-[0.2em] font-normal text-accent uppercase">
            {slug ? (
              <a href={`/projects/${slug}`} class="hover:opacity-80 transition-opacity">
                {title}
              </a>
            ) : (
              title
            )}
          </h2>
          <p class="text-text-secondary text-sm">{dateRange}</p>
          <p class="text-text-secondary text-sm">{location}</p>
          <div class="flex flex-wrap justify-center lg:justify-start gap-x-1 pt-1">
            {tags.map((tag) => (
              <span class="text-accent text-xs">#{tag}</span>
            ))}
          </div>
        </div>
        
        <!-- Description at bottom -->
        {description && (
          <p class="text-text-secondary text-sm leading-relaxed mt-auto pt-8 text-center md:text-center lg:text-justify max-w-sm mx-auto lg:mx-0">
            {description}
          </p>
        )}
        {link && (
          <a 
            href={link} 
            target="_blank" 
            rel="noopener noreferrer"
            class="inline-block text-accent text-xs underline underline-offset-2 hover:opacity-80 transition-opacity mt-4"
          >
            {link}
          </a>
        )}
      </div>
      
      <!-- Project Image - Right Column with frame effect -->
      <div class="flex items-start justify-center lg:justify-end">
        <div class="border border-[#6b6580] p-2 overflow-hidden w-full lg:w-[560px]" style="background-color: rgba(61, 56, 80, 0.3);">
          {slug ? (
            <a href={`/projects/${slug}`} class="block hover:opacity-80 transition-opacity">
              <Image
                src={image}
                alt={title}
                width={556}
                height={360}
                class="w-full lg:w-[556px] h-[240px] lg:h-[360px] object-cover"
                loading="lazy"
              />
            </a>
          ) : (
            <Image
              src={image}
              alt={title}
              width={556}
              height={360}
              class="w-full lg:w-[556px] h-[240px] lg:h-[360px] object-cover"
              loading="lazy"
            />
          )}
        </div>
      </div>
    </div>
  </div>
</article>
