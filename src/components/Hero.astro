---
interface Props {
  title: string;
  subtitle?: string;
  class?: string;
}

const { title, subtitle, class: className = '' } = Astro.props;
---

<section
  class:list={[
    'py-16 md:py-24 theme-transition',
    className,
  ]}
>
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-gray-100 mb-6">
        {title}
      </h1>

      {subtitle && (
        <p class="text-xl text-gray-600 dark:text-gray-400">
          {subtitle}
        </p>
      )}

      <div class="mt-8">
        <slot />
      </div>
    </div>
  </div>
</section>
