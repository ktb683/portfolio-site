---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-100 dark:bg-gray-900 text-gray-600 dark:text-gray-400 mt-auto border-t border-gray-200 dark:border-gray-800 theme-transition">
  <div class="container mx-auto px-4 py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-gray-900 dark:text-gray-100 font-semibold mb-3">Katie</h3>
        <p class="text-sm">Portfolio and Blog</p>
      </div>

      <div>
        <h3 class="text-gray-900 dark:text-gray-100 font-semibold mb-3">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Home</a></li>
          <li><a href="/portfolio" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Portfolio</a></li>
          <li><a href="/blog" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Blog</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-gray-900 dark:text-gray-100 font-semibold mb-3">Connect</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="https://github.com" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors" target="_blank" rel="noopener noreferrer">GitHub</a></li>
          <li><a href="https://linkedin.com" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
          <li><a href="mailto:contact@example.com" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Email</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-200 dark:border-gray-800 mt-8 pt-6 text-center text-sm">
      <p>&copy; {currentYear} Katie. All rights reserved.</p>
    </div>
  </div>
</footer>
