---
interface Props {
  title: string;
  description?: string;
  href?: string;
  tags?: string[];
  class?: string;
}

const { title, description, href, tags = [], class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'block p-6 rounded-xl border theme-transition',
    'bg-white dark:bg-gray-900',
    'border-gray-200 dark:border-gray-800',
    href && 'hover:border-primary-500 dark:hover:border-primary-400 hover:shadow-lg',
    className,
  ]}
>
  <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">
    {title}
  </h3>

  {description && (
    <p class="text-gray-600 dark:text-gray-400 text-sm mb-4">{description}</p>
  )}

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="px-2 py-1 text-xs rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">
          {tag}
        </span>
      ))}
    </div>
  )}

  <slot />
</Tag>
