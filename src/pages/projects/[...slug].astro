---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

// Helper function to format date range
function formatDateRange(startDate: Date, endDate?: Date, ongoing?: boolean): string {
  const startYear = startDate.getFullYear();
  if (ongoing) {
    return `${startYear} - ONGOING`;
  }
  if (endDate) {
    const endYear = endDate.getFullYear();
    return startYear === endYear ? `${startYear}` : `${startYear} - ${endYear}`;
  }
  return `${startYear}`;
}

const dateRange = formatDateRange(project.data.startDate, project.data.endDate, project.data.ongoing);
const allImages = [project.data.image, ...project.data.images].filter(Boolean);

const imageModules = import.meta.glob('../../content/projects/*/*.{png,jpg,jpeg,gif,webp}', {
  eager: true,
  as: 'url',
}) as Record<string, string>;

const projectImageMap: Record<string, string> = {};

for (const [path, url] of Object.entries(imageModules)) {
  const parts = path.split('/');
  const slug = parts[parts.length - 2];
  const filename = parts[parts.length - 1];
  projectImageMap[`${slug}/${filename}`] = url;
}
const folder = project.id.split('/')[0];
const imageUrls = allImages.map((img) => projectImageMap[`${folder}/${img}`] ?? '');

---

<Layout title={`${project.data.title} | Katie Ballinger`} description={project.data.description}>
  <div class="min-h-screen">
    <Header />
    
    <main class="pb-16">
      <article class="py-12">
        <div class="max-w-6xl mx-auto px-4 md:px-8">
          <!-- Header with title and metadata -->
          <div class="flex flex-col lg:flex-row gap-8 mb-8">
            <!-- Left: Main image -->
            <div class="lg:w-1/3">
              {allImages[0] && (
                <div class="border-4 border-border overflow-hidden">
                  <img 
                    src={imageUrls[0]} 
                    alt={project.data.title}
                    class="w-full h-auto object-cover"
                  />
                </div>
              )}
            </div>
            
            <!-- Right: Title, metadata, and secondary image -->
            <div class="lg:w-2/3 flex flex-col lg:flex-row gap-8">
              <div class="lg:w-1/2 space-y-3">
                <h1 class="text-2xl tracking-[0.15em] font-normal text-accent uppercase">
                  {project.data.title}
                </h1>
                <p class="text-text-secondary text-sm tracking-wide">{dateRange}</p>
                <p class="text-text-secondary text-sm">{project.data.location}</p>
                <div class="flex flex-wrap gap-1 pt-1">
                  {project.data.tags.map((tag: string) => (
                    <span class="text-accent text-xs">#{tag}</span>
                  ))}
                </div>
              </div>
              
              {allImages[1] && (
                <div class="lg:w-1/2">
                  <div class="border-4 border-border overflow-hidden">
                    <img 
                      src={imageUrls[1]} 
                      alt={`${project.data.title} - secondary`}
                      class="w-full h-auto object-cover"
                    />
                  </div>
                  {project.data.videoLink && (
                    <a 
                      href={project.data.videoLink} 
                      target="_blank" 
                      rel="noopener noreferrer"
                      class="inline-block text-accent text-xs underline underline-offset-2 hover:opacity-80 transition-opacity mt-3"
                    >
                      {project.data.videoLink}
                    </a>
                  )}
                </div>
              )}
            </div>
          </div>
          
          <!-- Description / Content -->
          <div class="max-w-lg">
            <div class="text-text-secondary text-sm leading-relaxed prose prose-invert prose-sm">
              <Content />
            </div>
          </div>
          
          <!-- Additional images -->
          {allImages.length > 2 && (
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mt-8">
              {imageUrls.slice(2).map((url, i) => (
                <div class="border-4 border-border overflow-hidden">
                  <img 
                    src={url} 
                    alt={`${project.data.title} - image ${i + 3}`}
                    class="w-full h-auto object-cover"
                  />
                </div>
              ))}
            </div>
          )}
          
          <!-- External links -->
          <div class="mt-8 flex gap-6">
            {project.data.externalLink && (
              <a 
                href={project.data.externalLink} 
                target="_blank" 
                rel="noopener noreferrer"
                class="text-accent text-sm underline underline-offset-2 hover:opacity-80 transition-opacity"
              >
                View Project
              </a>
            )}
            {project.data.github && (
              <a 
                href={project.data.github} 
                target="_blank" 
                rel="noopener noreferrer"
                class="text-accent text-sm underline underline-offset-2 hover:opacity-80 transition-opacity"
              >
                GitHub
              </a>
            )}
          </div>
          
          <!-- Back link -->
          <div class="mt-12">
            <a 
              href="/"
              class="text-text-secondary text-sm hover:text-accent transition-colors"
            >
              ← Back to Works
            </a>
          </div>
        </div>
      </article>
    </main>
  </div>
</Layout>
