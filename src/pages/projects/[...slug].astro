---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id.replace('/index.mdx', '').replace('/index.md', '') },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

// Helper function to format date range
function formatDateRange(startDate: Date, endDate?: Date, ongoing?: boolean): string {
  const startYear = startDate.getFullYear();
  if (ongoing) {
    return `${startYear} - ONGOING`;
  }
  if (endDate) {
    const endYear = endDate.getFullYear();
    return startYear === endYear ? `${startYear}` : `${startYear} - ${endYear}`;
  }
  return `${startYear}`;
}

const dateRange = formatDateRange(project.data.startDate, project.data.endDate, project.data.ongoing);

const imageModules = import.meta.glob('../../content/projects/*/*.{png,jpg,jpeg,gif,webp}', {
  eager: true,
}) as Record<string, { default: ImageMetadata }>;

const projectImageMap: Record<string, ImageMetadata> = {};

for (const [path, mod] of Object.entries(imageModules)) {
  const parts = path.split('/');
  const slugPart = parts[parts.length - 2];
  const filename = parts[parts.length - 1];
  projectImageMap[`${slugPart}/${filename}`] = mod.default;
}

const folder = project.id.split('/')[0].replace('/index.mdx', '').replace('/index.md', '');
const resolve = (f: string) => projectImageMap[`${folder}/${f}`];

const coverImage = resolve(project.data.image);

type GalleryItem = ImageMetadata | ImageMetadata[];
const resolvedGallery: GalleryItem[] = project.data.images
  .map((item) => {
    if (Array.isArray(item)) {
      return item.map(resolve).filter(Boolean) as ImageMetadata[];
    }
    return resolve(item);
  })
  .filter((item) => (Array.isArray(item) ? item.length > 0 : Boolean(item))) as GalleryItem[];

---

<Layout title={`${project.data.title} | Katie Ballinger`} description={project.data.description}>
  <div class="min-h-screen">
    <Header />
    
    <main class="pb-16">
      <article class="py-12">
        <div class="max-w-6xl mx-auto px-4 md:px-8">
          <!-- Header with title and metadata -->
          <div class="flex flex-col lg:flex-row gap-8 mb-8">
            <!-- Left: Main image -->
            <div class="lg:w-1/3">
              {coverImage && (
                <div class="border-4 border-border overflow-hidden">
                  <Image
                    src={coverImage}
                    alt={project.data.title}
                    width={coverImage.width}
                    height={coverImage.height}
                    class="w-full h-auto object-cover"
                  />
                </div>
              )}
            </div>
            
            <!-- Right: Title and metadata -->
            <div class="lg:w-2/3">
              <div class="space-y-3">
                <h1 class="text-2xl tracking-[0.15em] font-normal text-accent uppercase">
                  {project.data.title}
                </h1>
                <p class="text-text-secondary text-sm tracking-wide">{dateRange}</p>
                <p class="text-text-secondary text-sm">{project.data.location}</p>
                <div class="flex flex-wrap gap-1 pt-1">
                  {project.data.tags.map((tag: string) => (
                    <span class="text-accent text-xs">#{tag}</span>
                  ))}
                </div>
                {project.data.videoLink && (
                  <a
                    href={project.data.videoLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block text-accent text-xs underline underline-offset-2 hover:opacity-80 transition-opacity mt-3"
                  >
                    {project.data.videoLink}
                  </a>
                )}
              </div>
            </div>
          </div>
          
          <!-- Description / Content -->
          <div class="max-w-lg">
            <div class="text-text-secondary text-sm leading-relaxed prose prose-invert prose-sm [&_p]:mb-4 [&_a]:underline [&_a]:underline-offset-2">
              <Content />
            </div>
          </div>
          
          <!-- Additional images -->
          {resolvedGallery.length > 0 && (
            <div class="flex flex-col gap-4 mt-8">
              {resolvedGallery.map((item, i) =>
                Array.isArray(item) ? (
                  <div class="flex gap-4 items-start">
                    {item.map((img, j) => (
                      <div class="flex-1 min-w-0 border-4 border-border overflow-hidden">
                        <Image
                          src={img}
                          alt={`${project.data.title} - image ${i}-${j}`}
                          width={img.width}
                          height={img.height}
                          class="w-full h-auto"
                          loading="lazy"
                        />
                      </div>
                    ))}
                  </div>
                ) : (
                  <div class="border-4 border-border overflow-hidden">
                    <Image
                      src={item}
                      alt={`${project.data.title} - image ${i + 2}`}
                      width={item.width}
                      height={item.height}
                      class="w-full h-auto"
                      loading="lazy"
                    />
                  </div>
                )
              )}
            </div>
          )}
          
          <!-- External links -->
          <div class="mt-8 flex gap-6">
            {project.data.externalLink && (
              <a 
                href={project.data.externalLink} 
                target="_blank" 
                rel="noopener noreferrer"
                class="text-accent text-sm underline underline-offset-2 hover:opacity-80 transition-opacity"
              >
                View Project
              </a>
            )}
            {project.data.github && (
              <a 
                href={project.data.github} 
                target="_blank" 
                rel="noopener noreferrer"
                class="text-accent text-sm underline underline-offset-2 hover:opacity-80 transition-opacity"
              >
                GitHub
              </a>
            )}
          </div>
          
          <!-- Back link -->
          <div class="mt-12">
            <a 
              href="/"
              class="text-text-secondary text-sm hover:text-accent transition-colors"
            >
              ← Back to Portfolio
            </a>
          </div>
        </div>
      </article>
    </main>
  </div>
<style is:global>
  .prose a {
    color: var(--color-accent-400) !important;
  }
</style>
</Layout>
