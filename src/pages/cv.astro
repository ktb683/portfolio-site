---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import CreativeCV from '@components/cv/CreativeCV.astro';
import ProducerCV from '@components/cv/ProducerCV.astro';
import SoftwareCV from '@components/cv/SoftwareCV.astro';
---

<Layout title="CV | Katie Ballinger" description="Curriculum Vitae of Katie Ballinger">
  <div class="min-h-screen">
    <Header />

    <main class="py-16">
      <div class="max-w-4xl mx-auto px-4 md:px-8">
        <div class="flex items-center justify-between mb-12">
          <h1 id="cv-title" class="text-3xl tracking-[0.15em] font-normal text-accent uppercase transition-opacity duration-300">
            CV
          </h1>
          <div class="flex gap-3 text-xs tracking-widest uppercase text-text-secondary">
            <button id="cv-creative" class="cv-toggle hover:text-accent transition-colors" aria-pressed="false">Creative</button>
            <span class="opacity-30">|</span>
            <button id="cv-producer" class="cv-toggle hover:text-accent transition-colors" aria-pressed="false">Producer</button>
            <span class="opacity-30">|</span>
            <button id="cv-engineer" class="cv-toggle hover:text-accent transition-colors" aria-pressed="false">Software</button>
          </div>
        </div>

        <div id="view-creative" class="hidden"><CreativeCV /></div>
        <div id="view-producer" class="hidden"><ProducerCV /></div>
        <div id="view-engineer" class="hidden"><SoftwareCV /></div>

      </div>
    </main>
  </div>
</Layout>

<script>
  const title = document.getElementById('cv-title')!;
  const buttons = {
    creative: document.getElementById('cv-creative')!,
    producer: document.getElementById('cv-producer')!,
    engineer: document.getElementById('cv-engineer')!,
  };
  const views = {
    creative: document.getElementById('view-creative')!,
    producer: document.getElementById('view-producer')!,
    engineer: document.getElementById('view-engineer')!,
  };

  Object.entries(buttons).forEach(([key, btn]) => {
    btn.addEventListener('click', () => setView(key as keyof typeof views));
  });

  function setView(view: keyof typeof views) {
    title.textContent = 'CV';

    Object.entries(views).forEach(([key, el]) => {
      el.classList.toggle('hidden', key !== view);
    });
    Object.entries(buttons).forEach(([key, btn]) => {
      const active = key === view;
      btn.setAttribute('aria-pressed', String(active));
      btn.classList.toggle('text-accent', active);
    });
  }
</script>
