---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
---

<Layout title="CV | Katie Ballinger" description="Curriculum Vitae of Katie Ballinger">
  <div class="min-h-screen">
    <Header />
    
    <main class="py-16">
      <div class="max-w-4xl mx-auto px-8">
        <h1 class="text-3xl tracking-[0.15em] font-normal text-accent uppercase mb-12">
          CV
        </h1>
        
        <!-- Experience -->
        <section class="mb-12">
          <h2 class="text-lg tracking-[0.1em] text-accent uppercase mb-6 border-b border-border pb-2">
            Experience
          </h2>
          <div class="space-y-8">
            <div>
              <div class="flex flex-col sm:flex-row sm:justify-between sm:gap-4">
                <div>
                  <p class="text-text-primary">Technical Project Worker</p>
                  <p class="text-text-secondary text-sm">Aalto University — Espoo, FI</p>
                </div>
                <p class="text-text-secondary text-sm mt-1 sm:mt-0">Feb 2025–Present</p>
              </div>
              <p class="text-sm text-text-secondary mt-2">
                Field work involving drone videography and 3D scanning. Video and audio editing to produce content for interactive exhibitions, as well as social media.
              </p>
            </div>

            <div>
              <div class="flex flex-col sm:flex-row sm:justify-between sm:gap-4">
                <div>
                  <p class="text-text-primary">Chair / Board Member</p>
                  <p class="text-text-secondary text-sm">Kipsari Restaurant — Espoo, FI</p>
                </div>
                <p class="text-text-secondary text-sm mt-1 sm:mt-0">Apr 2024–Present</p>
              </div>
              <p class="text-sm text-text-secondary mt-2">
                Guide the board on making decisions for the direction of the restaurant, manage projects, handle official administrative duties, and meet with restaurant staff on a regular basis.
              </p>
            </div>

            <div>
              <div class="flex flex-col sm:flex-row sm:justify-between sm:gap-4">
                <div>
                  <p class="text-text-primary">Graphic Designer</p>
                  <p class="text-text-secondary text-sm">Aalto University — Espoo, FI</p>
                </div>
                <p class="text-text-secondary text-sm mt-1 sm:mt-0">Dec 2024–Jul 2025</p>
              </div>
              <p class="text-sm text-text-secondary mt-2">
                Designed 80+ informational posters for Aalto Studios to unify and showcase work spaces and technology available, in collaboration with colleagues through an iterative design process.
              </p>
            </div>

            <div>
              <div class="flex flex-col sm:flex-row sm:justify-between sm:gap-4">
                <div>
                  <p class="text-text-primary">Exhibition Assistant</p>
                  <p class="text-text-secondary text-sm">ARTS Infra – Aalto University — Espoo, FI</p>
                </div>
                <p class="text-text-secondary text-sm mt-1 sm:mt-0">2023</p>
              </div>
              <p class="text-sm text-text-secondary mt-2">
                Provided support to students and faculty using exhibition spaces at Aalto University including setup of lighting and equipment, and operation of a scissor lift.
              </p>
            </div>

            <div>
              <div class="flex flex-col sm:flex-row sm:justify-between sm:gap-4">
                <div>
                  <p class="text-text-primary">Executive Assistant to CTO</p>
                  <p class="text-text-secondary text-sm">Code in Chaos — Toronto, CA</p>
                </div>
                <p class="text-text-secondary text-sm mt-1 sm:mt-0">2021–2022</p>
              </div>
              <p class="text-sm text-text-secondary mt-2">
                Worked on administrative tasks across several companies including tax filings, scheduling, and payroll.
              </p>
            </div>

            <div>
              <div class="flex flex-col sm:flex-row sm:justify-between sm:gap-4">
                <div>
                  <p class="text-text-primary">Software Engineer</p>
                  <p class="text-text-secondary text-sm">Funding Circle — San Francisco, US</p>
                </div>
                <p class="text-text-secondary text-sm mt-1 sm:mt-0">2018–2020</p>
              </div>
              <p class="text-sm text-text-secondary mt-2">
                Programmed in Clojure on frontend and backend systems and hosted local monthly Clojure meetups for knowledge sharing, community building, and recruitment.
              </p>
            </div>
          </div>
        </section>

        <!-- Education -->
        <section class="mb-12">
          <h2 class="text-lg tracking-[0.1em] text-accent uppercase mb-6 border-b border-border pb-2">
            Education
          </h2>
          <div class="space-y-4">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:gap-4">
              <div>
                <p class="text-text-primary">MA New Media</p>
                <p class="text-text-secondary text-sm">Aalto University — Espoo, FI</p>
              </div>
              <p class="text-text-secondary text-sm mt-1 sm:mt-0">Aalto University</p>
            </div>
            <div class="flex flex-col sm:flex-row sm:justify-between sm:gap-4">
              <div>
                <p class="text-text-primary">BFA Digital Futures</p>
                <p class="text-text-secondary text-sm">OCAD University — Toronto, CA</p>
              </div>
              <p class="text-text-secondary text-sm mt-1 sm:mt-0">OCAD University</p>
            </div>
          </div>
        </section>

        <!-- Languages -->
        <section class="mb-12">
          <h2 class="text-lg tracking-[0.1em] text-accent uppercase mb-6 border-b border-border pb-2">
            Languages
          </h2>
          <div class="space-y-2">
            <p class="text-text-primary">English <span class="text-text-secondary text-sm">(Native speaker)</span></p>
            <p class="text-text-primary">Finnish <span class="text-text-secondary text-sm">(A2)</span></p>
          </div>
        </section>

        <!-- Skills -->
        <section class="mb-12">
          <h2 class="text-lg tracking-[0.1em] text-accent uppercase mb-6 border-b border-border pb-2">
            Skills
          </h2>
          <ul class="space-y-2 text-sm text-text-secondary list-disc list-inside">
            <li>Adobe Creative Cloud, Microsoft Office Suite, Arduino, video and audio editing, Clojure, HTML/CSS/JS, Git, AWS, Jira, Figma</li>
            <li>Video, audio, and lighting equipment operation and setup: video cameras, projectors, screens, video switchers, microphones, mixers, amps, and speakers</li>
            <li>Strong problem solving skills, adaptability, and technical troubleshooting</li>
            <li>Rapidly absorb new information and acquire skills</li>
            <li>High organization skill and ability to work across many platforms</li>
            <li>Leadership ability, strong communication, and critical thinking skills</li>
            <li>Event production experience and operational mindset</li>
          </ul>
        </section>
      </div>
    </main>
  </div>
</Layout>
