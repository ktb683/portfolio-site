---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';

// Get all projects sorted by date
const projects = await getCollection('projects', ({ data }) => !data.draft);
const sortedProjects = projects.sort((a, b) => {
  return b.data.startDate.getTime() - a.data.startDate.getTime();
});

// Helper function to format date range
function formatDateRange(startDate: Date, endDate?: Date, ongoing?: boolean): string {
  const startYear = startDate.getFullYear();
  if (ongoing) {
    return `${startYear} - ONGOING`;
  }
  if (endDate) {
    const endYear = endDate.getFullYear();
    return startYear === endYear ? `${startYear}` : `${startYear} - ${endYear}`;
  }
  return `${startYear}`;
}

const imageModules = import.meta.glob('../content/projects/*/*.{png,jpg,jpeg,gif,webp}', {
  eager: true,
}) as Record<string, { default: ImageMetadata }>;

const projectImageMap: Record<string, ImageMetadata> = {};

for (const [path, mod] of Object.entries(imageModules)) {
  const parts = path.split('/');
  const slug = parts[parts.length - 2];
  const filename = parts[parts.length - 1];
  projectImageMap[`${slug}/${filename}`] = mod.default;
}

const allTags = [...new Set(projects.flatMap(p => p.data.tags))].sort();

type ProjectEntry = (typeof projects)[number];

function getProjectFolder(project: ProjectEntry): string {
  return project.id.split('/')[0];
}

function getProjectImage(project: ProjectEntry): ImageMetadata {
  const filename = project.data.image.replace(/^\.\//, '');
  const key = `${getProjectFolder(project)}/${filename}`;
  return projectImageMap[key];
}

---

<Layout title="Katie Ballinger | Portfolio" description="Portfolio of creative works by Katie Ballinger">
  <div class="min-h-screen">
    <Header />
    
    <main class="pb-16">
      <!-- Controls bar -->
      <div class="px-4 md:px-8 pt-6 pb-2 max-w-6xl mx-auto">
        <div class="flex items-center justify-between">
          <!-- Tag filter (hidden) -->
          <div class="hidden">
            <button id="tags-toggle" class="flex items-center gap-2 text-xs tracking-widest uppercase text-text-secondary hover:text-accent transition-colors">
              <span>Filter</span>
              <svg id="tags-arrow" class="w-3 h-3 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          </div>
          <!-- View toggle -->
          <div class="flex gap-3 text-xs tracking-widest uppercase text-text-secondary">
            <button id="view-large" class="view-toggle hover:text-accent transition-colors" aria-pressed="true">List</button>
            <span class="opacity-30">|</span>
            <button id="view-small" class="view-toggle hover:text-accent transition-colors" aria-pressed="false">Gallery</button>
          </div>
        </div>
        <div id="tags-list" class="hidden flex-wrap gap-2 mt-3" style="display:none!important">
          {allTags.map((tag) => (
            <button
              class="tag-filter text-accent text-xs border border-accent px-3 py-1 hover:bg-accent hover:text-bg transition-colors"
              data-tag={tag}
            >
              #{tag}
            </button>
          ))}
        </div>
      </div>

      <!-- Large view -->
      <div id="large-view">
        {sortedProjects.map((project, i) => (
          <>
            {i > 0 && <div class="max-w-6xl mx-auto px-4 md:px-8"><hr class="border-t border-[#6b6580]" /></div>}
            <div class="project-item" data-tags={project.data.tags.join(',')}>
              <ProjectCard
                title={project.data.title}
                dateRange={project.data.hideDate ? '' : formatDateRange(project.data.startDate, project.data.endDate, project.data.ongoing)}
                location={project.data.location}
                tags={project.data.tags}
                image={getProjectImage(project)}

                slug={project.id.replace('/index.md', '')}
              />
            </div>
          </>
        ))}
      </div>

      <!-- Small view -->
      <div id="small-view" class="hidden px-4 md:px-8 pt-4 max-w-6xl mx-auto">
        <div class="grid grid-cols-2 md:flex md:flex-wrap gap-2">
          {sortedProjects.map((project) => (
            <a href={`/projects/${project.id.replace('/index.md', '')}`} class="project-item block hover:opacity-70 transition-opacity border border-[#6b6580] p-2" data-tags={project.data.tags.join(',')} style="background-color: rgba(61, 56, 80, 0.3);">
              <Image
                src={getProjectImage(project)}
                alt={project.data.title}
                width={200}
                height={200}
                class="w-full h-auto aspect-square md:w-[200px] md:h-[200px] object-cover"
                loading="lazy"
              />
            </a>
          ))}
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  // Tag filter
  const tagsToggle = document.getElementById('tags-toggle')!;
  const tagsList = document.getElementById('tags-list')!;
  const tagsArrow = document.getElementById('tags-arrow')!;
  const tagButtons = document.querySelectorAll<HTMLElement>('.tag-filter');
  const projectItems = document.querySelectorAll<HTMLElement>('.project-item');

  let activeTags = new Set<string>();

  tagsToggle.addEventListener('click', () => {
    const open = !tagsList.classList.contains('hidden');
    tagsList.classList.toggle('hidden', open);
    tagsList.classList.toggle('flex', !open);
    tagsArrow.style.transform = open ? '' : 'rotate(180deg)';
  });

  tagButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag!;
      if (activeTags.has(tag)) {
        activeTags.delete(tag);
        btn.classList.remove('bg-accent', 'text-bg');
        btn.classList.add('text-accent');
      } else {
        activeTags.add(tag);
        btn.classList.add('bg-accent', 'text-bg');
        btn.classList.remove('text-accent');
      }
      filterProjects();
    });
  });

  function filterProjects() {
    projectItems.forEach((item) => {
      if (activeTags.size === 0) {
        item.classList.remove('hidden');
        return;
      }
      const itemTags = item.dataset.tags?.split(',') ?? [];
      const match = [...activeTags].some((t) => itemTags.includes(t));
      item.classList.toggle('hidden', !match);
    });
  }

  // View toggle
  const listBtn = document.getElementById('view-large')!;
  const galleryBtn = document.getElementById('view-small')!;
  const listView = document.getElementById('large-view')!;
  const galleryView = document.getElementById('small-view')!;

  const saved = localStorage.getItem('works-view');
  if (saved === 'gallery') setView('gallery');
  else setView('list');

  listBtn.addEventListener('click', () => setView('list'));
  galleryBtn.addEventListener('click', () => setView('gallery'));

  function setView(view: 'list' | 'gallery') {
    const isList = view === 'list';
    listView.classList.toggle('hidden', !isList);
    galleryView.classList.toggle('hidden', isList);
    listBtn.setAttribute('aria-pressed', String(isList));
    galleryBtn.setAttribute('aria-pressed', String(!isList));
    listBtn.classList.toggle('text-accent', isList);
    galleryBtn.classList.toggle('text-accent', !isList);
    localStorage.setItem('works-view', view);
  }
</script>
