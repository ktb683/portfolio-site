---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

// Get all projects sorted by date
const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => {
  return b.data.startDate.getTime() - a.data.startDate.getTime();
});

// Helper function to format date range
function formatDateRange(startDate: Date, endDate?: Date, ongoing?: boolean): string {
  const startYear = startDate.getFullYear();
  if (ongoing) {
    return `${startYear} - ONGOING`;
  }
  if (endDate) {
    const endYear = endDate.getFullYear();
    return startYear === endYear ? `${startYear}` : `${startYear} - ${endYear}`;
  }
  return `${startYear}`;
}

const imageModules = import.meta.glob('../content/projects/*/*.{png,jpg,jpeg,gif,webp}', {
  eager: true,
  as: 'url',
}) as Record<string, string>;

const projectImageMap: Record<string, string> = {};

for (const [path, url] of Object.entries(imageModules)) {
  const parts = path.split('/');
  const slug = parts[parts.length - 2];
  const filename = parts[parts.length - 1];
  projectImageMap[`${slug}/${filename}`] = url;
}

type ProjectEntry = (typeof projects)[number];

function getProjectFolder(project: ProjectEntry): string {
  return project.id.split('/')[0];
}

function getProjectImageUrl(project: ProjectEntry): string {
  const filename = project.data.image.replace(/^\.\//, '');
  const key = `${getProjectFolder(project)}/${filename}`;
  return projectImageMap[key] ?? '';
}

---

<Layout title="Katie Ballinger | Works" description="Portfolio of creative works by Katie Ballinger">
  <div class="min-h-screen">
    <Header />
    
    <main class="pb-16">
      <!-- View toggle -->
      <div class="flex justify-end px-4 md:px-8 pt-6 pb-2 max-w-6xl mx-auto">
        <div class="flex gap-3 text-xs tracking-widest uppercase text-text-secondary">
          <button id="view-large" class="view-toggle hover:text-accent transition-colors" aria-pressed="true">Large</button>
          <span class="opacity-30">|</span>
          <button id="view-small" class="view-toggle hover:text-accent transition-colors" aria-pressed="false">Small</button>
        </div>
      </div>

      <!-- Large view -->
      <div id="large-view">
        {sortedProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            dateRange={formatDateRange(project.data.startDate, project.data.endDate, project.data.ongoing)}
            location={project.data.location}
            tags={project.data.tags}
            image={getProjectImageUrl(project)}
            description={project.data.description}
            slug={project.slug}
          />
        ))}
      </div>

      <!-- Small view -->
      <div id="small-view" class="hidden px-4 md:px-8 pt-4 max-w-6xl mx-auto">
        <div class="flex flex-wrap gap-2">
          {sortedProjects.map((project) => (
            <a href={`/projects/${project.slug}`} class="block hover:opacity-70 transition-opacity border border-[#6b6580] p-2" style="background-color: rgba(61, 56, 80, 0.3);">
              <img
                src={getProjectImageUrl(project)}
                alt={project.data.title}
                class="w-[100px] h-[100px] object-cover"
                loading="lazy"
              />
            </a>
          ))}
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  const largeBtn = document.getElementById('view-large')!;
  const smallBtn = document.getElementById('view-small')!;
  const largeView = document.getElementById('large-view')!;
  const smallView = document.getElementById('small-view')!;

  const saved = localStorage.getItem('works-view');
  if (saved === 'small') setView('small');

  largeBtn.addEventListener('click', () => setView('large'));
  smallBtn.addEventListener('click', () => setView('small'));

  function setView(view: 'large' | 'small') {
    const isLarge = view === 'large';
    largeView.classList.toggle('hidden', !isLarge);
    smallView.classList.toggle('hidden', isLarge);
    largeBtn.setAttribute('aria-pressed', String(isLarge));
    smallBtn.setAttribute('aria-pressed', String(!isLarge));
    largeBtn.classList.toggle('text-accent', isLarge);
    smallBtn.classList.toggle('text-accent', !isLarge);
    localStorage.setItem('works-view', view);
  }
</script>
